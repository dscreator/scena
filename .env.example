# OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Simple chat (/api/chat) model — Vercel + local
# OPENAI_CHAT_MODEL=gpt-4.1

# Agent Builder workflow id — if set (e.g. on Vercel), the app uses ChatKit; otherwise simple chat
CHATKIT_WORKFLOW_ID=

# Optional: force simple chat UI even when CHATKIT_WORKFLOW_ID is set (off | 0 | false)
# CHATKIT_UI=off

# Optional: session API port (default 8787)
# PORT=8787
