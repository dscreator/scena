# OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Simple chat (/api/chat) model — Vercel + local
# OPENAI_CHAT_MODEL=gpt-4.1

# Set to "true" for ChatKit (needs CHATKIT_WORKFLOW_ID + domain key in index.html)
# VITE_USE_CHATKIT=true

# Workflow id from Agent Builder (ChatKit only; required on Vercel if VITE_USE_CHATKIT=true)
CHATKIT_WORKFLOW_ID=

# Optional: session API port (default 8787)
# PORT=8787
